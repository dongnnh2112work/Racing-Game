{
  "name": "motion-platform",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "server/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @howls/game-racing",
    "dev:server": "npm run dev -w @howls/motion-server",
    "build": "npm run build -w @howls/motion-server && npm run build -w @howls/game-racing",
    "start": "npm run start -w @howls/game-racing",
    "eslint": "npm run eslint -w @howls/game-racing",
    "prepare": "husky install"
  },
  "devDependencies": {
    "husky": "^7.0.4",
    "lint-staged": "^12.3.4",
    "prettier": "^2.5.1",
    "typescript": "^5.9.3"
  },
  "license": "MIT",
  "lint-staged": {
    "*.{js,jsx,ts,tsx,md}": "prettier --write"
  }
}
